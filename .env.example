# Copia este archivo a .env.local (apps/web) y/o .env (apps/mcp) y rellena los valores.
# Sin las variables de Supabase, la web arranca en modo demo (ver apps/web/src/server/mode.ts):
# sin autenticación real y con datos en memoria, útil para evaluar la UI sin crear ningún proyecto.

# --- apps/web ---------------------------------------------------------------

# Panel del proyecto Supabase > Project Settings > API. Público: se usa en cliente y servidor,
# pero el acceso a datos siempre pasa por Row Level Security (RLS), nunca por esta clave sola.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth se configura directamente en el panel de Supabase (Authentication > Providers >
# Google), con el Client ID/Secret de Google Cloud Console. No hace falta duplicarlos aquí:
# la app solo llama a supabase.auth.signInWithOAuth({ provider: "google" }).
# URL de redirect a registrar en Google Cloud Console y en Supabase:
#   https://<tu-proyecto>.supabase.co/auth/v1/callback
# Y en Supabase > Authentication > URL Configuration, añade como Redirect URL:
#   https://tu-dominio.example/auth/callback
#
# Solo para desarrollo local con `supabase start` (leídas por supabase/config.toml):
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# OpenRouter: análisis de entrenamientos por IA (apps/web/src/server/openrouter.ts).
# Sin OPENROUTER_API_KEY, el endpoint de análisis responde "no disponible" en vez de fallar.
OPENROUTER_API_KEY=
# Router gratuito recomendado para pruebas. Puedes sustituirlo por un modelo concreto con sufijo :free.
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Opcionales, recomendados por OpenRouter para aparecer en su ranking de apps.
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=RPeak

# --- apps/mcp -----------------------------------------------------------------
# Servidor MCP stdio: usa la service role key (bypassa RLS), así que filtra siempre
# manualmente por RPEAK_USER_ID. No lo despliegues con acceso multiusuario compartido.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# UUID del usuario (auth.users.id) cuyos planes/entrenamientos gestiona esta instancia del MCP.
RPEAK_USER_ID=
