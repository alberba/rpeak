{
  "name": "rpeak",
  "private": true,
  "version": "0.1.0",
  "description": "RPeak — cuaderno de entrenamiento en vivo (PWA)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "start": "npm run start -w apps/web",
    "lint": "npm run lint -w apps/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "mcp": "npm run start -w apps/mcp",
    "mcp:dev": "npm run dev -w apps/mcp",
    "import:exercises": "node scripts/import-exercises.mjs",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
