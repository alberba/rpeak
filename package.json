{
  "name": "rpeak",
  "private": true,
  "version": "0.1.0",
  "description": "RPeak — cuaderno de entrenamiento en vivo (PWA)",
  "scripts": {
    "dev": "pnpm --filter web run dev",
    "build": "pnpm --filter web run build",
    "start": "pnpm --filter web run start",
    "lint": "pnpm --filter web run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "mcp": "pnpm --filter @rpeak/mcp run start",
    "mcp:dev": "pnpm --filter @rpeak/mcp run dev",
    "import:exercises": "node scripts/import-exercises.mjs",
    "ci": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.6.0"
}
